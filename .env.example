# Copy this file to .env and adjust the values for your environment.
# docker-compose.yml reads these variables automatically.

# S3 / MinIO connection
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_REGION=us-east-1

# Go backend listen address (container-internal)
LISTEN_ADDR=:8080
